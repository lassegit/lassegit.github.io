{
  "name": "simple-gatsby-blog",
  "description": "",
  "version": "1.0.0",
  "author": "Lasse T. <lassetange@gmail.com>",
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "gatsby": "5.16.1",
    "gatsby-plugin-catch-links": "5.16.0",
    "gatsby-plugin-feed": "5.16.0",
    "gatsby-plugin-react-helmet": "6.16.0",
    "gatsby-plugin-sass": "6.16.0",
    "gatsby-plugin-sharp": "5.16.0",
    "gatsby-remark-copy-linked-files": "6.16.0",
    "gatsby-remark-images": "7.16.0",
    "gatsby-remark-prismjs": "7.16.0",
    "gatsby-source-filesystem": "5.16.0",
    "gatsby-transformer-remark": "6.16.0",
    "node-normalize-scss": "^8.0.0",
    "prismjs": "1.30.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-helmet": "6.1.0",
    "sass": "1.99.0"
  },
  "keywords": [
    "gatsby"
  ],
  "license": "MIT",
  "scripts": {
    "serve": "gatsby serve",
    "build": "gatsby build",
    "dev": "gatsby develop",
    "format": "prettier --write 'src/**/*.js'",
    "test": "echo \"Error: no test specified\" && exit 1",
    "deploy": "gatsby build && cp CNAME public/ && gh-pages -b master -d public",
    "lint": "yarn lint:js",
    "lint:fix": "./node_modules/eslint/bin/eslint.js . --fix --cache",
    "lint:js": "./node_modules/eslint/bin/eslint.js . --cache"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.js": [
      "./node_modules/eslint/bin/eslint.js . --fix --cache",
      "git add"
    ]
  },
  "devDependencies": {
    "babel-eslint": "^10.0.1",
    "eslint": "^5.13.0",
    "eslint-config-airbnb": "^17.1.0",
    "eslint-config-prettier": "^4.0.0",
    "eslint-plugin-codebox": "^2.0.2",
    "eslint-plugin-import": "^2.16.0",
    "eslint-plugin-jsx-a11y": "^6.2.1",
    "eslint-plugin-prettier": "^3.0.1",
    "eslint-plugin-react": "^7.12.4",
    "gh-pages": "^1.2.0",
    "husky": "^1.3.1",
    "lint-staged": "^8.1.3",
    "prettier": "^1.16.4"
  }
}
